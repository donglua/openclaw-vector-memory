# Zilliz Cloud 配置
# 注册地址：https://cloud.zilliz.com（免费层可用）
ZILLIZ_URI=https://your-cluster-id.api.gcp-us-west1.zillizcloud.com
ZILLIZ_TOKEN=your_api_key_here

# Collection 名称
COLLECTION_NAME=openclaw_memories

# ─────────────────────────────────────────────────────────────────
# Embedding 后端选择（四选一）
# local        本地 BGE-M3，完整 dense+sparse 混合搜索（默认）
# siliconflow  硅基流动 API，dense only
# openai       OpenAI 或兼容 API，dense only
# custom_http  自部署 HTTP 服务，dense only
#
EMBEDDING_PROVIDER=local
# ─────────────────────────────────────────────────────────────────

# ── 硅基流动（EMBEDDING_PROVIDER=siliconflow 时填写）────────────
# 注册：https://cloud.siliconflow.cn
# SILICONFLOW_API_KEY=sk-xxx
# SILICONFLOW_MODEL=BAAI/bge-m3

# ── OpenAI 或兼容 API（EMBEDDING_PROVIDER=openai 时填写）────────
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1   # 改为其他兼容服务地址
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── 自定义 HTTP（EMBEDDING_PROVIDER=custom_http 时填写）─────────
# EMBEDDING_API_URL=http://localhost:8000/embed

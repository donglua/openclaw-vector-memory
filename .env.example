# Zilliz Cloud 配置
# 注册：https://cloud.zilliz.com（免费层可用）
ZILLIZ_URI=https://your-cluster-id.api.gcp-us-west1.zillizcloud.com
ZILLIZ_TOKEN=your_api_key_here
COLLECTION_NAME=openclaw_memories

# ─────────────────────────────────────────────────────────────────
# Embedding 后端：local（默认）或 remote
#   local   本地 BGE-M3，完整 dense+sparse 混合搜索
#   remote  任意 OpenAI 兼容 API，dense only
EMBEDDING_PROVIDER=local

# ── 远程 API 配置（EMBEDDING_PROVIDER=remote 时填写）────────────
# 示例：硅基流动
# EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024

# 示例：OpenAI
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536
